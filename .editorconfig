# Duotech — EditorConfig (https://editorconfig.org)
# Đảm bảo mọi editor (VSCode, JetBrains, vim...) format whitespace giống nhau.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false  # 2 space cuối dòng = line break trong Markdown

[Makefile]
indent_style = tab
